# e-Xabar — muhit o'zgaruvchilari namunasi.
# Nusxa oling: .env (DB/Redis) + .env.local (maxfiy), keyin qiymatlarni to'ldiring.

# --- .env (Prisma CLI + runtime) ---
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/exabar?schema=public"
REDIS_URL="redis://localhost:6379"

# --- .env.local (Next.js runtime, maxfiy) ---
# Auth.js v5
AUTH_SECRET=""              # openssl rand -base64 32
AUTH_URL="http://localhost:3000"

# Settings shifrlash kaliti (32 bayt hex)
ENCRYPTION_KEY=""           # node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# CVE manba API kalitlari
NVD_API_KEY=""
GITHUB_TOKEN=""

# SMTP
SMTP_HOST="smtp-relay.gmail.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="security@example.uz"
